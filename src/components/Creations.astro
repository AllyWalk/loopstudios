---
const creations = [
  { title: "Deep Earth", imgName: "image-deep-earth.jpg" },
  { title: "Night Arcade", imgName: "image-night-arcade.jpg" },
  { title: "Soccer Team VR", imgName: "image-soccer-team.jpg" },
  { title: "The Grid", imgName: "image-grid.jpg" },
  { title: "From Up Above VR", imgName: "image-from-above.jpg" },
  { title: "Pocket Borealis", imgName: "image-pocket-borealis.jpg" },
  { title: "The Curiosity", imgName: "image-curiosity.jpg" },
  { title: "Make it Fisheye", imgName: "image-fisheye.jpg" },
];
---

<section class="max-w-6xl mx-auto px-6 py-24">
  <div class="flex justify-between items-center mb-12">
    <h2 class="text-4xl md:text-5xl uppercase font-light font-josefin">
      Our Creations
    </h2>
    <button class="hidden md:block border-2 border-black px-10 py-2 uppercase tracking-[0.3em] font-alata hover:bg-black hover:text-white transition-colors duration-300">
      See All
    </button>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
    {creations.map((item) => (
      <div class="relative group cursor-pointer overflow-hidden bg-white">
        
        <img 
          src={`/images/mobile/${item.imgName}`} 
          alt={item.title} 
          class="w-full md:hidden transition duration-300 group-hover:opacity-30" 
        />

        <img 
          src={`/images/desktop/${item.imgName}`} 
          alt={item.title} 
          class="hidden md:block w-full transition duration-300 group-hover:scale-110 group-hover:opacity-30" 
        />
        
        <div class="absolute inset-0 bg-gradient-to-r md:bg-gradient-to-t from-black/70 to-transparent transition-opacity duration-300 group-hover:opacity-0"></div>
        
        <h3 class="absolute bottom-4 left-6 md:bottom-8 md:left-8 text-white text-2xl md:text-3xl uppercase w-min leading-[0.9] font-light transition-colors duration-300 group-hover:text-black z-10 font-josefin">
          {item.title}
        </h3>
        
      </div>
    ))}
  </div>

  <div class="flex justify-center mt-8 md:hidden">
    <button class="border-2 border-black px-10 py-2 uppercase tracking-[0.3em] font-alata hover:bg-black hover:text-white transition-colors duration-300 w-full">
      See All
    </button>
  </div>
</section>

<style>
  .font-josefin { font-family: 'Josefin Sans', sans-serif; }
  .font-alata { font-family: 'Alata', sans-serif; }
</style>